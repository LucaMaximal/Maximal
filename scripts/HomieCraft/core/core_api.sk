#
# HomieCraft Core API
# File:
# /plugins/Skript/scripts/HomieCraft/core/core_api.sk
#

#
# NETWORK
#

function hc_network() :: text:
    return "&bHomieCraft"

function hc_network_plain() :: text:
    return "HomieCraft"

function hc_version() :: text:
    return "&c0.0.1-dev+260515"

function hc_version_plain() :: text:
    return "0.0.1-dev+260515"

function hc_mcversion() :: text:
    return "&f1.21.11"

function hc_mcversion_plain() :: text:
    return "1.21.11"

function hc_status() :: text:
    return "&aONLINE"

function hc_status_dev() :: text:
    return "&eDEVELOPMENT"

function hc_status_maintenance() :: text:
    return "&cMAINTENANCE"

#
# PREFIXES
#

function hc_prefix_main() :: text:
    return "&8[&bHomieCraft&8] &7"

function hc_prefix_chat() :: text:
    return "&8[&dHomieCraft-Chat&8] &7"

function hc_prefix_player() :: text:
    return "&8[&aHomieCraft-Player&8] &7"

