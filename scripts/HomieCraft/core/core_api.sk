function hc_prefix_anticheat() :: text:
    return "&8[&4HomieCraft-Anticheat&8] &7"

function hc_prefix_network() :: text:
    return "&8[&9HomieCraft-Network&8] &7"

function hc_prefix_lobby() :: text:
    return "&8[&6HomieCraft-Lobby&8] &7"

function hc_prefix_social() :: text:
    return "&8[&5HomieCraft-Social&8] &7"

function hc_prefix_staff() :: text:
    return "&8[&3HomieCraft-Staff&8] &7"

function hc_prefix_admin() :: text:
    return "&8[&4HomieCraft-Administration&8] &7"

